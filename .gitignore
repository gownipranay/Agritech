# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# ML artifacts — ignore checkpoints by default, but commit the shipped one so
# the deployed backend can serve predictions without retraining.
ml/checkpoints/*.pt
ml/checkpoints/*.pth
!ml/checkpoints/disease_model.pt
ml/data/plantvillage/
ml/data/raw/
*.onnx

# Synthetic smoke-test images (regenerate with make_sample_dataset.py) and
# real datasets once downloaded — large/generated, not source
data/sample_images/
data/plantvillage/
data/plantvillage_raw/
data/raw/

# Claude Code session-local state
.claude/

# Node / frontend
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.netlify/

# Env / secrets
.env
.env.*
!.env.example
backend/.env

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log

# Raw crop datasets (maize/rice/cotton/chilli/groundnut) — large, regenerate via kaggle
data/crop_raw/
